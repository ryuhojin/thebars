# Required Cloudflare Pages secrets for the current admin runtime.
SETUP_TOKEN=
ADMIN_RECOVERY_TOKEN=

# D1 is configured as a Cloudflare Pages binding named DB, not as env vars.
# Keep database names/IDs out of committed files.

# Required for production publication. Local tests keep using fake adapters unless D1 is bound.
CUSTOMER_REPO_OWNER=
CUSTOMER_REPO_NAME=
CUSTOMER_REPO_BRANCH=main
CUSTOMER_REPO_ROOT=customer-menu-board
GITHUB_FINE_GRAINED_PAT=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PROJECT_NAME=
